# AlphaESS Open API credentials (from https://open.alphaess.com/)
ALPHAESS_APP_ID=your_app_id
ALPHAESS_APP_SECRET=your_app_secret
ALPHAESS_SYS_SN=your_system_serial_number

# InfluxDB
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change_me
INFLUX_ORG=home
INFLUX_BUCKET=alphaess
INFLUX_TOKEN=generate_a_long_random_token_here
INFLUX_PORT=8086

# Grafana (bundled instance; ignored with the NAS overlay, see DEPLOY.md)
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Collector
POLL_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Battery-savings analysis (pricing.py)
# Usable battery capacity in kWh, used only to express the daily SoC change in
# kWh on the dashboard. Optional. NOTE: on this system the reported SoC appears
# compressed (moves ~1/2.8 of measured throughput), so treat the kWh figure as
# directional. Euro results do not depend on it.
BATTERY_CAPACITY_KWH=27.9

# Optional dead-man's switch: URL of an Uptime Kuma "Push" monitor. The
# collector pings it after each successful InfluxDB write, so a stuck-but-alive
# collector (API auth expired, writes failing) still trips the monitor. Leave
# blank to disable. Set the Kuma monitor's grace period > POLL_INTERVAL_SECONDS.
HEARTBEAT_URL=

# AWTRIX pusher (Ulanzi TC001 / AWTRIX 3 clock) — optional.
# LAN IP (or full URL) of the clock, e.g. AWTRIX_HOST=192.168.1.42. Reserve a
# static IP for it on your router. Leave blank to disable (service idles).
AWTRIX_HOST=
PUSH_INTERVAL_SECONDS=30
STALE_AFTER_SECONDS=180
# Optional AWTRIX icons per app. Value = an icon name/ID present on the device
# (upload via the AWTRIX web UI Icons page, which can fetch by LaMetric ID from
# https://developer.lametric.com/icons). Blank = text label instead of an icon.
AWTRIX_ICON_SOC=
AWTRIX_ICON_PV=
AWTRIX_ICON_GRID=
AWTRIX_ICON_LOAD=
