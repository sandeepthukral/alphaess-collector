# AlphaESS Open API credentials (from https://open.alphaess.com/)
ALPHAESS_APP_ID=your_app_id
ALPHAESS_APP_SECRET=your_app_secret
ALPHAESS_SYS_SN=your_system_serial_number

# InfluxDB
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change_me
INFLUX_ORG=home
INFLUX_BUCKET=alphaess
INFLUX_TOKEN=generate_a_long_random_token_here
INFLUX_PORT=8086

# Grafana (bundled instance; ignored with the NAS overlay, see DEPLOY.md)
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Collector
POLL_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Battery-savings analysis (pricing.py)
# Usable battery capacity in kWh, used only to express the daily SoC change in
# kWh on the dashboard. Optional. NOTE: on this system the reported SoC appears
# compressed (moves ~1/2.8 of measured throughput), so treat the kWh figure as
# directional. Euro results do not depend on it.
BATTERY_CAPACITY_KWH=27.9
