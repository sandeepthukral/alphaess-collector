            "uid": "${DS_ALPHAESS}"
          },
          "query": "from(bucket: \"alphaess\")\n  |> range(start: 2020-01-01T00:00:00Z)\n  |> filter(fn: (r) => r._measurement == \"daily_cost\" and r.model_version == \"${model_version}\" and r._field == \"saving\")\n  |> group()\n  |> sum()\n  |> yield(name: \"total_saving\")",
